{
  "name": "auto-redbook-content",
  "version": "2.0.0",
  "description": "小红书内容抓取与改写工具，支持图片识别和 OCR，输出本地 JSON 文件",
  "main": "scripts/fetch.js",
  "scripts": {
    "test": "node scripts/fetch.js 3"
  },
  "keywords": [
    "openclaw",
    "skill",
    "xiaohongshu",
    "redbook",
    "content",
    "automation",
    "image-recognition",
    "ocr",
    "rewrite"
  ],
  "author": "OpenClaw Community",
  "license": "MIT",
  "dependencies": {
    "dotenv": "17.3.1"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "openclaw": {
    "type": "skill",
    "triggers": [
      "抓取小红书笔记",
      "自动生成小红书内容",
      "运行 auto-redbook-content",
      "执行小红书内容流程"
    ],
    "permissions": [
      "exec:mcporter",
      "exec:moltshell-vision",
      "exec:image-ocr",
      "fs:read:.env",
      "fs:write:output",
      "fs:write:/tmp/xhs-images",
      "network:https"
    ],
    "env": {
      "REWRITE_MODE": {
        "required": false,
        "default": "direct",
        "description": "改写模式：direct 或 agent"
      },
      "AGENT_ID": {
        "required": false,
        "description": "Agent ID（agent 模式必需）"
      }
    },
    "dependencies": {
      "tools": [
        "mcporter (xiaohongshu MCP)",
        "moltshell-vision",
        "image-ocr"
      ],
      "external": [
        "tesseract-ocr"
      ],
      "optional": {
        "agent_mode": [
          "sessions_spawn",
          "其他 agent（如 libu）"
        ]
      }
    }
  }
}
