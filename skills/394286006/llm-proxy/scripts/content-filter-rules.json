{
  "version": "2.0",
  "description": "LLM 响应内容安全审计规则 - 分级审核",
  
  "layer1_malicious": {
    "name": "第一层：恶意指令检测",
    "enabled": true,
    "rules": [
      {
        "id": "CMD-001",
        "name": "危险系统命令",
        "severity": "critical",
        "patterns": [
          "rm\\s+-rf\\s+[/~]",
          "rm\\s+-rf\\s+\\*",
          "mkfs\\.",
          "dd\\s+if=.*of=/dev/",
          ":(){ :|:& };:",
          "chmod\\s+777\\s+/",
          "chown\\s+-R\\s+"
        ]
      },
      {
        "id": "CMD-002",
        "name": "提权操作",
        "severity": "critical",
        "patterns": [
          "sudo\\s+su\\s*$",
          "sudo\\s+passwd",
          "chmod\\s+u\\+s",
          "chmod\\s+4755"
        ]
      },
      {
        "id": "SQL-001",
        "name": "SQL注入/删除",
        "severity": "critical",
        "patterns": [
          "DROP\\s+TABLE",
          "DROP\\s+DATABASE",
          "DELETE\\s+FROM.*WHERE\\s+1\\s*=\\s*1",
          "TRUNCATE\\s+TABLE"
        ]
      },
      {
        "id": "NET-001",
        "name": "数据外泄",
        "severity": "critical",
        "patterns": [
          "curl\\s+.*-d\\s+.*@",
          "wget\\s+.*--post",
          "nc\\s+-e\\s+/bin",
          "bash\\s+-i\\s+>&\\s+/dev/tcp"
        ]
      },
      {
        "id": "NET-002",
        "name": "网络扫描/攻击工具",
        "severity": "high",
        "patterns": [
          "nmap\\s+",
          "sqlmap",
          "hydra\\s+",
          "metasploit"
        ]
      },
      {
        "id": "BACKDOOR-001",
        "name": "后门/反弹shell",
        "severity": "critical",
        "patterns": [
          "/bin/bash\\s+-i",
          "socat\\s+.*EXEC",
          "mkfifo\\s+.*\\/tmp",
          "perl.*Socket.*exec"
        ]
      }
    ]
  },
  
  "layer2_sensitive": {
    "name": "第二层：敏感内容检测",
    "enabled": true,
    "rules": [
      {
        "id": "PII-001",
        "name": "个人身份信息",
        "severity": "high",
        "patterns": [
          "\\d{17}[\\dXx]",
          "\\d{15}(?=\\D|$)",
          "1[3-9]\\d{9}",
          "[\\w.-]+@[\\w.-]+\\.\\w{2,}"
        ]
      },
      {
        "id": "PII-002",
        "name": "银行卡/信用卡",
        "severity": "high",
        "patterns": [
          "\\d{16,19}",
          "\\d{3,4}[\\s-]?\\d{4}[\\s-]?\\d{4}[\\s-]?\\d{4}",
          "CVV.{0,3}\\d{3,4}",
          "有效期.{0,10}\\d{2}/\\d{2}"
        ]
      },
      {
        "id": "CRED-001",
        "name": "凭证/密钥泄露",
        "severity": "critical",
        "patterns": [
          "sk-[a-zA-Z0-9]{20,}",
          "AKIA[0-9A-Z]{16}",
          "ghp_[a-zA-Z0-9]{36}",
          "password\\s*[=:]\\s*['\"][^'\"]+['\"]",
          "api[_-]?key\\s*[=:]\\s*['\"][^'\"]+['\"]",
          "token\\s*[=:]\\s*['\"][^'\"]{20,}['\"]"
        ]
      },
      {
        "id": "SECRET-001",
        "name": "敏感配置泄露",
        "severity": "high",
        "patterns": [
          "BEGIN\\s+(RSA|DSA|EC)\\s+PRIVATE\\s+KEY",
          "jdbc:.*password=",
          "mysql://.*:.*@",
          "postgres://.*:.*@"
        ]
      },
      {
        "id": "LEGAL-001",
        "name": "违法内容",
        "severity": "critical",
        "patterns": [
          "制作.{0,5}(炸弹|毒品|枪支)",
          "如何.{0,5}(洗钱|诈骗)",
          "黑客.{0,5}(攻击|入侵).{0,20}(教程|方法)",
          "盗取.{0,10}(账号|密码|数据)"
        ]
      },
      {
        "id": "INTERNAL-001",
        "name": "内部信息泄露",
        "severity": "medium",
        "patterns": [
          "内部.{0,5}(密码|口令)",
          "管理.{0,5}(员|后台).{0,10}(密码|账号)",
          "数据库.{0,5}(密码|连接)",
          "服务器.{0,5}(密码|密钥)"
        ]
      }
    ]
  },
  
  "layer3_llm_review": {
    "name": "第三层：LLM 智能审核",
    "enabled": false,
    "model": "openrouter/google/gemma-3-4b-it:free",
    "prompt_template": "判断以下AI回复是否包含安全隐患。只回答 JSON：{\"safe\": true/false, \"reason\": \"原因\", \"category\": \"分类\"}\n\nAI回复内容：\n{content}",
    "timeout_seconds": 10
  },
  
  "whitelist": [
    "rm\\s+-rf\\s+/tmp/",
    "rm\\s+-rf\\s+\\./node_modules",
    "example\\.com",
    "your[_-]?api[_-]?key",
    "sk-xxx",
    "\\*{3,}",
    "password\\s*=\\s*\\*+"
  ],
  
  "response_actions": {
    "critical": {
      "block": false,
      "log": true,
      "alert": true,
      "replace_with": "[内容被安全审计拦截：发现严重安全隐患]"
    },
    "high": {
      "block": false,
      "log": true,
      "alert": true,
      "replace_with": null
    },
    "medium": {
      "block": false,
      "log": true,
      "alert": false
    },
    "low": {
      "block": false,
      "log": true,
      "alert": false
    }
  }
}
